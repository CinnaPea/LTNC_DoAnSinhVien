{
  "openapi": "3.0.3",
  "info": {
    "title": "DoAnSinhVien API",
    "version": "v1",
    "description": "Static OpenAPI document for the Rails API used by the Spring Boot frontend."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "tags": [
    { "name": "AdminUsers", "description": "Single-admin user management endpoints." },
    { "name": "TheLoai", "description": "CRUD for topic records." },
    { "name": "DangKy", "description": "Registration CRUD plus approve and reject workflow." },
    { "name": "DoAn", "description": "Thesis records created from approved registrations." },
    { "name": "TienDo", "description": "Progress updates linked to a thesis." },
    { "name": "BaiDang", "description": "Submission and report entries linked to a thesis." },
    { "name": "DanhGia", "description": "Evaluation records that complete or reopen a thesis." }
  ],
  "paths": {
    "/up": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": { "description": "Application is healthy" }
        }
      }
    },
    "/api/admin/users": {
      "get": {
        "tags": ["AdminUsers"],
        "summary": "List users",
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/AdminUser" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["AdminUsers"],
        "summary": "Create academic user",
        "description": "Creates an SV or GV account. The SQL trigger is expected to create the linked profile row.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AdminUserCreateRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AdminUser" }
              }
            }
          },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/api/admin/users/{id}": {
      "get": {
        "tags": ["AdminUsers"],
        "summary": "Show user",
        "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
        "responses": {
          "200": {
            "description": "User detail",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AdminUser" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFoundError" }
        }
      },
      "patch": {
        "tags": ["AdminUsers"],
        "summary": "Update academic user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AdminUserUpdateRequest" }
            }
          }
        },
        "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
        "responses": {
          "200": {
            "description": "Updated user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AdminUser" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      },
      "delete": {
        "tags": ["AdminUsers"],
        "summary": "Delete academic user",
        "description": "Deletes the NguoiDung row and relies on the SQL trigger/procedure cascade to remove linked academic records.",
        "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
        "responses": {
          "204": { "description": "Deleted successfully" },
          "404": { "$ref": "#/components/responses/NotFoundError" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
